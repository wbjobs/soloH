APP_NAME=ProteinContactPrediction
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql://postgres:password@localhost:5432/protein_contact
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

MODEL_CACHE_DIR=./data/models
DEFAULT_MODEL_NAME=resnet50_pdb

THRESHOLD_ANGSTROM=8.0
MAX_SEQUENCE_LENGTH=1000

BLAST_DB_PATH=/data/blast/uniref90
BLASTP_PATH=/usr/bin/blastp
PSIBLAST_PATH=/usr/bin/psiblast
