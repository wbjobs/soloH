# 环境变量示例 - 复制为 .env 并填入实际值

# Mapbox Access Token (必须)
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJja2V5In0.your-token-here

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agridisease

# Redis配置
REDIS_URL=redis://localhost:6379

# JWT配置
SECRET_KEY=your-super-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 邮件配置 (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=农业病害预警系统

# WRF预报数据配置
WRF_DATA_DIR=/data/wrf
WRF_API_URL=https://api.wrf-model.example.com
WRF_API_KEY=your-wrf-api-key

# 系统配置
GRID_RESOLUTION_KM=1
RISK_CALCULATION_INTERVAL_MINUTES=60
ALERT_CHECK_INTERVAL_MINUTES=15
