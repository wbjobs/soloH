# 应用配置
APP_NAME=CRISPR Off-Target Predictor
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=86400

# 参考基因组配置
GENOME_REFERENCE_PATH=./data/hg38.fa
GENOME_BUILD=hg38

# 模型配置
MODEL_PATH=./models/crispr_model.pt
MODEL_DEVICE=cpu
MAX_MISMATCHES=6
MAX_INDEL=2
BATCH_SIZE=32

# IGV配置
IGV_BASE_URL=http://localhost:60151
IGV_GENOME=hg38

# ATAC-seq染色质可及性数据
ATAC_PEAK_PATH=./data/atac_peaks.narrowPeak
DEFAULT_CELL_TYPE=default

# 功能开关
ENABLE_CHROMATIN_CORRECTION=true
ENABLE_EFFICIENCY_PREDICTION=true
ENABLE_REPAIR_PREDICTION=true
CHROMATIN_CORRECTION_WEIGHT=0.3

# 限流配置
RATE_LIMIT=100
RATE_LIMIT_WINDOW=60
